{{!-- Group Manager - Simplified --}}
<div class="cyphur-manager-container">
    <div class="cyphur-manager-header">
        <h3><i class="fas fa-users-cog"></i> {{localize "CYPHUR.Groups.Title"}}</h3>
    </div>

    <div class="cyphur-manager-content">
        {{!-- Two Column Layout --}}
        <div class="cyphur-two-column">
            {{!-- Existing Groups --}}
            <div class="cyphur-column">
                <div class="cyphur-column-header">
                    <span>{{localize "CYPHUR.Hub.Groups"}}</span>
                    <div class="cyphur-selection-actions">
                        <button type="button" class="cyphur-btn-icon" data-action="openSelected" disabled title="{{localize 'CYPHUR.OpenChat'}}">
                            <i class="fas fa-folder-open"></i>
                        </button>
                        <button type="button" class="cyphur-btn-icon" data-action="exportSelected" disabled title="{{localize 'CYPHUR.Export'}}">
                            <i class="fas fa-file-export"></i>
                        </button>
                        <button type="button" class="cyphur-btn-icon" data-action="deleteSelected" disabled title="{{localize 'CYPHUR.Delete'}}">
                            <i class="fas fa-trash"></i>
                        </button>
                    </div>
                </div>
                
                <div class="cyphur-group-list">
                    {{#each groups}}
                    <div class="cyphur-group-item" data-group-id="{{this.id}}">
                        <input type="checkbox" class="cyphur-group-check">
                        <div class="cyphur-group-info">
                            <div class="cyphur-group-name">{{this.name}}</div>
                            <div class="cyphur-group-meta">
                                {{this.memberCount}} {{localize "CYPHUR.Members"}} · {{this.messageCount}} msgs
                            </div>
                        </div>
                        <button type="button" class="cyphur-btn-icon" data-action="editGroup" title="{{localize 'CYPHUR.Edit'}}">
                            <i class="fas fa-edit"></i>
                        </button>
                        <button type="button" class="cyphur-btn-icon" data-action="openGroup" title="{{localize 'CYPHUR.OpenChat'}}">
                            <i class="fas fa-folder-open"></i>
                        </button>
                    </div>
                    {{else}}
                    <div class="cyphur-empty-state">
                        <i class="fas fa-users"></i>
                        <p>{{localize "CYPHUR.Groups.NoGroups"}}</p>
                    </div>
                    {{/each}}
                </div>
            </div>

            {{!-- Create New Group --}}
            <div class="cyphur-column">
                <div class="cyphur-column-header">
                    <span>{{localize "CYPHUR.Groups.CreateNew"}}</span>
                </div>

                <div class="cyphur-form-group">
                    <label>{{localize "CYPHUR.GroupName"}}</label>
                    <input type="text" name="newGroupName" placeholder="{{localize 'CYPHUR.Groups.GroupNamePlaceholder'}}">
                </div>

                <div class="cyphur-form-group">
                    <label>{{localize "CYPHUR.Groups.Members"}}</label>
                    <div class="cyphur-member-select">
                        {{#each users}}
                        <label class="cyphur-member-option">
                            <input type="checkbox" value="{{this.id}}">
                            <span>{{this.name}}</span>
                            {{#if this.isGM}}<span class="cyphur-gm-badge">GM</span>{{/if}}
                            {{#if this.isOnline}}<span class="cyphur-online-dot"></span>{{/if}}
                        </label>
                        {{/each}}
                    </div>
                </div>

                <button type="button" class="cyphur-btn cyphur-btn-primary" data-action="createGroup">
                    <i class="fas fa-plus"></i> {{localize "CYPHUR.Buttons.CreateGroup"}}
                </button>
            </div>
        </div>
    </div>
</div>
